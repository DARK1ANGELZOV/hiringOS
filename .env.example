POSTGRES_DB=hiringos
POSTGRES_USER=hiringos
POSTGRES_PASSWORD=change_this_password

JWT_SECRET_KEY=change_this_access_secret
JWT_REFRESH_SECRET_KEY=change_this_refresh_secret
ACCESS_TOKEN_EXPIRES_MINUTES=30
REFRESH_TOKEN_EXPIRES_DAYS=14
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

CORS_ORIGINS=http://localhost:3000
FRONTEND_PUBLIC_API_URL=http://localhost:8000/api/v1
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=
ACCESS_COOKIE_NAME=hiringos_access
REFRESH_COOKIE_NAME=hiringos_refresh
CSRF_COOKIE_NAME=hiringos_csrf

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET_DOCUMENTS=documents

MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_EXTENSIONS=.pdf,.doc,.docx,.jpg,.jpeg,.png
ALLOWED_UPLOAD_MIME_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,image/jpeg,image/png
SIGNED_URL_EXPIRE_SECONDS=900
MALWARE_SCAN_BLOCK_ON_DETECTION=true
MALWARE_SCAN_BLOCK_ON_ERROR=false

ADMIN_BOOTSTRAP_TOKEN=

RESUME_LLM_MODEL_ID=Qwen/Qwen2.5-1.5B-Instruct
INTERVIEW_LLM_MODEL_ID=Qwen/Qwen2.5-1.5B-Instruct
EMBEDDING_MODEL_ID=sentence-transformers/all-MiniLM-L6-v2
STT_MODEL_ID=openai/whisper-small
TTS_MODEL_ID=microsoft/speecht5_tts
TTS_VOCODER_MODEL_ID=microsoft/speecht5_hifigan
TTS_SPEAKER_DATASET_ID=Matthijs/cmu-arctic-xvectors
TTS_FEMALE_SPEAKER_HINT=slt
VIDEO_ANALYSIS_MODEL_ID=openai/clip-vit-base-patch32

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
